# App base URL (Host / Unraid reverse proxy URL)
NEXT_PUBLIC_BASE_URL=https://party.example.com

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://party.example.com/api/auth/callback

# External MongoDB container (NOT managed by this app)
MONGODB_URI=mongodb://<user>:<password>@<mongo-host>:27017/partyqueue?authSource=admin
MONGODB_DB_NAME=partyqueue
